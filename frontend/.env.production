# Production Environment Variables for Frontend
# This file is for reference only - set these in Vercel

# API Configuration - Use Next.js API routes for frontend-only deployment
NEXT_PUBLIC_API_URL=/api

# App Configuration
NEXT_PUBLIC_APP_NAME=Course Management System
NEXT_PUBLIC_APP_URL=course-management-system-five.vercel.app

# Analytics (Optional)
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
